@page "/messagelog"
@using AsteriskManager.Services
@inject AsteriskService Asterisk
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Message Log</PageTitle>

<h1>Asterisk Message Log</h1>

<div class="d-flex gap-2 mb-3 align-items-center">
    <label class="form-label mb-0">Lines:</label>
    <input type="number" class="form-control" style="width:100px" @bind="_lineCount" min="10" max="5000" />
    <button class="btn btn-primary" @onclick="RefreshAsync" disabled="@_busy">
        @(_busy ? "Loading..." : "Refresh")
    </button>
    <div class="form-check ms-3">
        <input class="form-check-input" type="checkbox" id="autoRefreshMsg" @bind="_autoRefresh" />
        <label class="form-check-label" for="autoRefreshMsg">Auto-refresh (5s)</label>
    </div>
</div>

<pre class="log-viewer p-3">@_logContent</pre>

@code {
    private string _logContent = string.Empty;
    private int _lineCount = 200;
    private bool _busy;
    private bool _autoRefresh;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_autoRefresh && _cts == null)
        {
            _cts = new CancellationTokenSource();
            _ = AutoRefreshLoopAsync(_cts.Token);
        }
        else if (!_autoRefresh && _cts != null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
            _cts = null;
        }
    }

    private async Task AutoRefreshLoopAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            await Task.Delay(5000, ct).ContinueWith(_ => { });
            if (ct.IsCancellationRequested) break;
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshAsync()
    {
        _busy = true;
        try { _logContent = await Asterisk.ReadMessageLogTailAsync(_lineCount); }
        catch (Exception ex) { _logContent = "Error reading log: " + ex.Message; }
        _busy = false;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
